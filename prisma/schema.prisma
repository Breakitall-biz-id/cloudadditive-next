// prisma/schema.prisma
// CloudAdditive - 3D Printing Service Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USERS ====================

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  emailVerified         DateTime?
  passwordHash          String?
  passwordResetToken    String?   @unique
  passwordResetExpires  DateTime?
  name                  String
  phone                 String?
  avatarUrl             String?
  twoFactorEnabled      Boolean   @default(false)
  role                  Role      @default(CUSTOMER)
  
  // Relations
  provider        Provider?
  orders          Order[]
  addresses       Address[]
  accounts        Account[]
  sessions        Session[]
  notificationSettings UserNotificationSettings?
  auditLogs       AuditLog[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([email])
  @@index([role])
}

model UserNotificationSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailEnabled      Boolean  @default(true)

  orderConfirmed    Boolean  @default(true)
  printStarted      Boolean  @default(true)
  printCompleted    Boolean  @default(true)
  shippingUpdate    Boolean  @default(true)

  paymentSuccess    Boolean  @default(true)
  paymentReminder   Boolean  @default(true)
  refund            Boolean  @default(true)

  promo             Boolean  @default(false)
  newsletter        Boolean  @default(false)
  productUpdate     Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

enum Role {
  ADMIN
  PROVIDER
  CUSTOMER
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label           String   @default("Home")
  recipientName   String
  phone           String
  street          String   @db.Text
  city            String
  province        String
  postalCode      String
  latitude        Float?
  longitude       Float?
  isDefault       Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
}

// ==================== PROVIDERS & PRINTERS ====================

model Provider {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  businessName    String
  description     String?   @db.Text
  logoUrl         String?
  
  // Business Details
  businessType        String?           // "Individual", "CV/PT", "Enterprise"
  businessNumber      String?           // NIB (Nomor Induk Berusaha)
  
  // Location
  street          String?   @db.Text
  city            String
  province        String
  postalCode      String?
  latitude        Float?
  longitude       Float?
  
  // Capabilities
  primaryTechnology   String?           // FDM, SLA, MJF, etc.
  supportedMaterials  Json?             // ["PLA", "PETG", "ABS", ...]
  
  // Bank Account (for payouts)
  bankName            String?
  bankAccountNumber   String?
  bankAccountName     String?           // Name on account
  
  // Verification
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  
  // Relations
  printers        Printer[]
  orders          Order[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
  @@index([isVerified])
}

model Printer {
  id              String    @id @default(cuid())
  providerId      String
  provider        Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  name            String
  model           String?
  technology      PrintTech @default(FDM)
  
  // Build Volume (mm)
  buildWidth      Int       @default(220)
  buildDepth      Int       @default(220)
  buildHeight     Int       @default(250)
  
  // Connection (Pusher-based)
  connectionToken String?   @unique
  octoprintUrl    String?
  octoprintApiKey String?
  webcamUrl       String?
  
  // Status
  status          PrinterStatus @default(OFFLINE)
  lastSeenAt      DateTime?
  currentJobId    String?
  lastTemperatures Json?       // Last known temperatures (hotend, bed)
  lastJobInfo     Json?        // Last known job info (filename, progress, timeRemaining)
  
  // Auto-dispatch: Current filament loaded
  currentMaterialId   String?
  currentMaterial     Material? @relation("LoadedMaterial", fields: [currentMaterialId], references: [id])
  
  // Auto-dispatch: Readiness toggle
  isAcceptingOrders   Boolean   @default(false)
  
  // Preprocessing time buffer (minutes) after each print
  preprocessingTime   Int       @default(10)
  
  // Relations
  materials       PrinterMaterial[]
  orders          Order[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([providerId])
  @@index([status])
  @@index([connectionToken])
}

enum PrintTech {
  FDM
  SLA
  SLS
  DLP
}

enum PrinterStatus {
  ONLINE
  OFFLINE
  PRINTING
  PAUSED
  MAINTENANCE
  ERROR
}

// ==================== MATERIALS & QUALITY ====================

model Material {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("Filament")
  description     String?   @db.Text
  
  // Properties
  density         Float     @default(1.24)
  diameter        Float     @default(1.75)
  
  // Pricing (per gram)
  pricePerGram    Decimal   @db.Decimal(10, 2)
  
  // Print settings defaults
  nozzleTemp      Int?
  bedTemp         Int?
  
  // Available colors
  colors          MaterialColor[]
  
  // Which printers support this
  printers        PrinterMaterial[]
  
  // Orders using this material
  orders          Order[]
  
  // Printers currently loaded with this material
  loadedInPrinters Printer[] @relation("LoadedMaterial")
  
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([name])
  @@index([isActive])
}

model MaterialColor {
  id              String    @id @default(cuid())
  materialId      String
  material        Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  
  name            String
  hexCode         String
  
  isAvailable     Boolean   @default(true)
  
  @@index([materialId])
}

model PrinterMaterial {
  id              String    @id @default(cuid())
  printerId       String
  printer         Printer   @relation(fields: [printerId], references: [id], onDelete: Cascade)
  materialId      String
  material        Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  
  // Printer-specific settings for this material
  nozzleTemp      Int?
  bedTemp         Int?
  
  @@unique([printerId, materialId])
  @@index([printerId])
  @@index([materialId])
}

model PrintQuality {
  id              String    @id @default(cuid())
  name            String
  description     String?
  
  // Layer height in mm
  layerHeight     Float
  
  // Speed multiplier (affects time & price)
  speedMultiplier Float     @default(1.0)
  
  // Price multiplier 
  priceMultiplier Float     @default(1.0)
  
  orders          Order[]
  
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  
  @@index([isActive])
}

// ==================== ORDERS & PAYMENTS ====================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  
  // Customer
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  
  // Provider & Printer (assigned after location selection)
  providerId      String?
  provider        Provider?   @relation(fields: [providerId], references: [id])
  printerId       String?
  printer         Printer?    @relation(fields: [printerId], references: [id])
  
  // Files
  stlFileUrl      String
  stlFileName     String
  stlFileSize     Int
  gcodeFileUrl    String?
  thumbnailUrl    String?
  
  // Print Configuration
  materialId      String
  material        Material    @relation(fields: [materialId], references: [id])
  colorName       String?
  colorHex        String?
  qualityId       String
  quality         PrintQuality @relation(fields: [qualityId], references: [id])
  quantity        Int         @default(1)
  
  // Slicing Results
  estimatedPrintTime  Int?
  filamentLengthMm    Float?
  filamentWeightG     Float?
  modelVolumeCm3      Float?
  modelWidth          Float?
  modelHeight         Float?
  modelDepth          Float?
  
  // Pricing (snapshot at order time)
  printingCost    Decimal     @db.Decimal(12, 2)
  shippingCost    Decimal     @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  totalPrice      Decimal     @db.Decimal(12, 2)
  
  // Shipping
  shippingAddress String      @db.Text
  shippingLat     Float
  shippingLng     Float
  courierCode     String?
  courierService  String?
  trackingNumber  String?
  
  // Status
  status          OrderStatus @default(PENDING_PAYMENT)
  
  // Queue position tracking
  queuePosition   Int?
  printStartedAt  DateTime?
  printCompletedAt DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  
  // Relations
  payment         Payment?
  statusHistory   OrderStatusHistory[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([userId])
  @@index([providerId])
  @@index([printerId])
  @@index([status])
  @@index([orderNumber])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_FAILED
  CONFIRMED
  IN_QUEUE
  SLICING
  PRINTING
  POST_PROCESSING
  PACKING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  status      OrderStatus
  note        String?     @db.Text
  changedBy   String?
  
  createdAt   DateTime    @default(now())
  
  @@index([orderId])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  
  // Midtrans
  invoiceNumber   String        @unique
  snapToken       String?
  snapUrl         String?
  
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   String?
  status          PaymentStatus @default(PENDING)
  
  paidAt          DateTime?
  expiredAt       DateTime?
  
  // Midtrans callback data
  rawResponse     Json?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([invoiceNumber])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  REFUNDED
}

// ==================== ADMIN AUDIT ====================

model AuditLog {
  id          String          @id @default(cuid())
  actorId     String?
  actor       User?           @relation(fields: [actorId], references: [id], onDelete: SetNull)

  action      AdminActionType
  entityType  String
  entityId    String
  reason      String          @db.Text
  metadata    Json?

  createdAt   DateTime        @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum AdminActionType {
  PROVIDER_VERIFIED
  PROVIDER_UNVERIFIED
  USER_ROLE_CHANGED
  ORDER_STATUS_CHANGED
  ORDER_ASSIGNMENT_CHANGED
  PAYMENT_STATUS_CHANGED
  PRINTER_UPDATED
  MATERIAL_UPDATED
  PRINT_QUALITY_UPDATED
  SYSTEM_SETTINGS_UPDATED
}

// ==================== SYSTEM SETTINGS ====================

model SystemSettings {
  id                      String   @id @default("default")
  
  // Fee percentages (set by admin)
  markupPercentage        Float    @default(0.15)  // 15% markup for provider
  platformFeePercentage   Float    @default(0.10)  // 10% platform fee
  
  // Machine rate (per hour in IDR)
  machineRatePerHour      Float    @default(10000) // Rp 10.000/jam
  
  // Estimated print speed (mm³ per hour) for quick estimates
  estimatedPrintSpeed     Float    @default(15000) // 15 cm³/hour for FDM
  
  // Default infill percentage for estimates
  defaultInfillPercentage Float    @default(0.20)  // 20% infill
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
