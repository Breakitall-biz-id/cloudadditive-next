// prisma/schema.prisma
// CloudAdditive - 3D Printing Service Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USERS ====================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  passwordHash    String?
  name            String
  phone           String?
  avatarUrl       String?
  role            Role      @default(CUSTOMER)
  
  // Relations
  provider        Provider?
  orders          Order[]
  addresses       Address[]
  accounts        Account[]
  sessions        Session[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([email])
  @@index([role])
}

enum Role {
  ADMIN
  PROVIDER
  CUSTOMER
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label           String   @default("Home")
  recipientName   String
  phone           String
  street          String   @db.Text
  city            String
  province        String
  postalCode      String
  latitude        Float?
  longitude       Float?
  isDefault       Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
}

// ==================== PROVIDERS & PRINTERS ====================

model Provider {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  businessName    String
  description     String?   @db.Text
  logoUrl         String?
  
  // Location
  street          String?   @db.Text
  city            String
  province        String
  latitude        Float
  longitude       Float
  serviceRadius   Int       @default(100)
  
  // Status
  isVerified      Boolean   @default(false)
  isActive        Boolean   @default(true)
  rating          Float     @default(0)
  totalOrders     Int       @default(0)
  
  // Relations
  printers        Printer[]
  orders          Order[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([city])
  @@index([isVerified, isActive])
}

model Printer {
  id              String        @id @default(cuid())
  providerId      String
  provider        Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  name            String
  model           String?
  technology      PrintTech     @default(FDM)
  
  // Build volume (mm)
  buildWidth      Int
  buildDepth      Int  
  buildHeight     Int
  
  // Supported materials (many-to-many)
  materials       PrinterMaterial[]
  
  // OctoPrint connection
  octoprintUrl    String?
  octoprintApiKey String?
  tunnelUsername  String?
  tunnelPassword  String?
  
  // Status
  status          PrinterStatus @default(OFFLINE)
  lastSeenAt      DateTime?
  currentJobId    String?
  
  // Queue
  orders          Order[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([providerId])
  @@index([status])
}

enum PrintTech {
  FDM
  SLA
  SLS
  DLP
}

enum PrinterStatus {
  ONLINE
  OFFLINE
  PRINTING
  PAUSED
  MAINTENANCE
  ERROR
}

// ==================== MATERIALS & QUALITY ====================

model Material {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("Filament")
  description     String?   @db.Text
  
  // Properties
  density         Float     @default(1.24)
  diameter        Float     @default(1.75)
  
  // Pricing (per gram)
  pricePerGram    Decimal   @db.Decimal(10, 2)
  
  // Print settings defaults
  nozzleTemp      Int?
  bedTemp         Int?
  
  // Available colors
  colors          MaterialColor[]
  
  // Which printers support this
  printers        PrinterMaterial[]
  
  // Orders using this material
  orders          Order[]
  
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([name])
  @@index([isActive])
}

model MaterialColor {
  id              String    @id @default(cuid())
  materialId      String
  material        Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  
  name            String
  hexCode         String
  
  isAvailable     Boolean   @default(true)
  
  @@index([materialId])
}

model PrinterMaterial {
  id              String    @id @default(cuid())
  printerId       String
  printer         Printer   @relation(fields: [printerId], references: [id], onDelete: Cascade)
  materialId      String
  material        Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  
  // Printer-specific settings for this material
  nozzleTemp      Int?
  bedTemp         Int?
  
  @@unique([printerId, materialId])
  @@index([printerId])
  @@index([materialId])
}

model PrintQuality {
  id              String    @id @default(cuid())
  name            String
  description     String?
  
  // Layer height in mm
  layerHeight     Float
  
  // Speed multiplier (affects time & price)
  speedMultiplier Float     @default(1.0)
  
  // Price multiplier 
  priceMultiplier Float     @default(1.0)
  
  orders          Order[]
  
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  
  @@index([isActive])
}

// ==================== ORDERS & PAYMENTS ====================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  
  // Customer
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  
  // Provider & Printer (assigned after location selection)
  providerId      String?
  provider        Provider?   @relation(fields: [providerId], references: [id])
  printerId       String?
  printer         Printer?    @relation(fields: [printerId], references: [id])
  
  // Files
  stlFileUrl      String
  stlFileName     String
  stlFileSize     Int
  gcodeFileUrl    String?
  thumbnailUrl    String?
  
  // Print Configuration
  materialId      String
  material        Material    @relation(fields: [materialId], references: [id])
  colorName       String?
  colorHex        String?
  qualityId       String
  quality         PrintQuality @relation(fields: [qualityId], references: [id])
  quantity        Int         @default(1)
  
  // Slicing Results
  estimatedPrintTime  Int?
  filamentLengthMm    Float?
  filamentWeightG     Float?
  modelVolumeCm3      Float?
  modelWidth          Float?
  modelHeight         Float?
  modelDepth          Float?
  
  // Pricing (snapshot at order time)
  printingCost    Decimal     @db.Decimal(12, 2)
  shippingCost    Decimal     @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  totalPrice      Decimal     @db.Decimal(12, 2)
  
  // Shipping
  shippingAddress String      @db.Text
  shippingLat     Float
  shippingLng     Float
  courierCode     String?
  courierService  String?
  trackingNumber  String?
  
  // Status
  status          OrderStatus @default(PENDING_PAYMENT)
  
  // Queue position tracking
  queuePosition   Int?
  printStartedAt  DateTime?
  printCompletedAt DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  
  // Relations
  payment         Payment?
  statusHistory   OrderStatusHistory[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([userId])
  @@index([providerId])
  @@index([printerId])
  @@index([status])
  @@index([orderNumber])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_FAILED
  CONFIRMED
  IN_QUEUE
  SLICING
  PRINTING
  POST_PROCESSING
  PACKING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  status      OrderStatus
  note        String?     @db.Text
  changedBy   String?
  
  createdAt   DateTime    @default(now())
  
  @@index([orderId])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  
  // Midtrans
  invoiceNumber   String        @unique
  snapToken       String?
  snapUrl         String?
  
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   String?
  status          PaymentStatus @default(PENDING)
  
  paidAt          DateTime?
  expiredAt       DateTime?
  
  // Midtrans callback data
  rawResponse     Json?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([invoiceNumber])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  REFUNDED
}

// ==================== SYSTEM SETTINGS ====================

model SystemSettings {
  id                      String   @id @default("default")
  
  // Fee percentages (set by admin)
  markupPercentage        Float    @default(0.15)  // 15% markup for provider
  platformFeePercentage   Float    @default(0.10)  // 10% platform fee
  
  // Machine rate (per hour in IDR)
  machineRatePerHour      Float    @default(10000) // Rp 10.000/jam
  
  // Estimated print speed (mm³ per hour) for quick estimates
  estimatedPrintSpeed     Float    @default(15000) // 15 cm³/hour for FDM
  
  // Default infill percentage for estimates
  defaultInfillPercentage Float    @default(0.20)  // 20% infill
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

